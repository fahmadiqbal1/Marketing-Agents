# =============================================================================
# AI Marketing Platform - Environment Configuration
# Copy this file to .env and fill in your actual values
# =============================================================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_CHAT_ID=your_chat_id_here

# --- MySQL Database ---
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=marketing_platform
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=marketing_platform

# --- OpenAI (for GPT-4o-mini captions, resume screening) ---
OPENAI_API_KEY=sk-your_openai_api_key_here

# --- Google Gemini (for vision analysis - cheapest option) ---
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# --- Google OAuth (for YouTube & Calendar) ---
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# --- Facebook / Instagram (Meta Graph API) ---
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here
META_PAGE_ACCESS_TOKEN=your_page_access_token_here
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id_here

# --- LinkedIn ---
LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here
LINKEDIN_ORGANIZATION_ID=your_linkedin_org_id_here

# --- TikTok ---
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token_here

# --- SerpAPI (for hashtag/keyword research) ---
SERPAPI_API_KEY=your_serpapi_key_here

# --- Redis (optional, for posting queue) ---
REDIS_URL=redis://localhost:6379/0

# --- Media Storage ---
MEDIA_STORAGE_PATH=./media

# --- Background Music ---
MUSIC_ENABLED=true
DEFAULT_MUSIC_VOLUME=0.2
MUSIC_FADE_IN_SECONDS=1.0
MUSIC_FADE_OUT_SECONDS=2.0
# Put royalty-free MP3s in this folder:
# MUSIC_LIBRARY_PATH=./media/music_library

# --- Business Brand Info (use dashboard Settings page instead) ---
DEFAULT_WEBSITE=https://www.yourbusiness.com
DEFAULT_PHONE=+1-XXX-XXX-XXXX
DEFAULT_ADDRESS=Your business address

# --- Growth Hacking ---
# GMB post suggestions auto-generated after each publish (uses existing OpenAI key)
# WhatsApp status images auto-generated from photos (uses Pillow locally, free)
